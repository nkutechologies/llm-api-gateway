# ---------- Provider API Keys ----------
# Set these environment variables to configure providers.
# Keys set here take priority over keys entered via the UI.

# Free-tier providers
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
TOGETHER_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
SAMBANOVA_API_KEY=
DEEPSEEK_API_KEY=
FIREWORKS_API_KEY=
NVIDIA_API_KEY=
CLOUDFLARE_API_KEY=
# Ollama runs locally — no key needed

# Paid-tier providers (fallback)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# ---------- Gateway Settings ----------
GATEWAY_CONFIG_DIR=./data
GATEWAY_API_URL=http://localhost:8000
